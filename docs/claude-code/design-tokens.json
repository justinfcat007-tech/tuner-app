{
  "meta": {
    "name": "Warm Acoustic Precision",
    "version": "1.0.0",
    "target": "mobile web and Capacitor Android"
  },
  "color": {
    "canvas": "#10151D",
    "surface": "#18212C",
    "surfaceRaised": "#202C39",
    "surfaceWarm": "#F7F0E3",
    "textPrimary": "#F8FAFC",
    "textSecondary": "#B8C2CC",
    "textMuted": "#7F8A96",
    "ink": "#1A222C",
    "accent": "#E7B65C",
    "accentStrong": "#C98B32",
    "accentSoft": "#F8E1B3",
    "success": "#63C79A",
    "warning": "#EEB45B",
    "danger": "#E97979",
    "border": "#314050",
    "borderStrong": "#4A5D70",
    "overlay": "rgba(5, 10, 16, 0.48)"
  },
  "font": {
    "sans": "Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif",
    "display": "Georgia, 'Times New Roman', serif",
    "size": {
      "caption": "12px",
      "body": "15px",
