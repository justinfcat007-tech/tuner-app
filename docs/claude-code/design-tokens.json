  "radius": {
    "sm": "10px",
    "md": "16px",
    "lg": "24px",
    "pill": "999px"
  },
  "shadow": {
    "card": "0 8px 24px rgba(0, 0, 0, 0.20)",
    "sheet": "0 -12px 40px rgba(0, 0, 0, 0.32)"
  },
  "motion": {
    "fast": "150ms",
    "normal": "220ms",
    "easing": "cubic-bezier(0.2, 0.8, 0.2, 1)"
