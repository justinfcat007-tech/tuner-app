# 使用 `docker compose --env-file .env.production up -d --build` 前复制并填写。
DOMAIN=tuner.example.com

MYSQL_ROOT_PASSWORD=replace-with-a-long-random-root-password
DB_NAME=tuner_app
DB_USER=tuner_app
DB_PASS=replace-with-a-long-random-password
JWT_SECRET=replace-with-a-random-32-plus-character-secret

# 真实支付接入、回调验签和金额校验完成前必须保持 false。
PAYMENTS_ENABLED=false
